# Neo configuration. Copy to .env and fill in what you use.
# .env is gitignored; never commit real keys.

# Flask session secret (any long random string)
NEO_SECRET_KEY=change-me

# Default provider/model for new agents: gemini | openai | claude | local | mock
NEO_PROVIDER=gemini
NEO_MODEL=gemini-2.5-flash

# Provider keys (set at least one)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local / self-hosted models via any OpenAI-compatible endpoint (Ollama, LM Studio, vLLM)
NEO_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
NEO_LOCAL_API_KEY=local
NEO_LOCAL_MODELS=llama3.1,qwen2.5-coder

# Storage: sqlite needs zero setup; mysql needs the settings below
NEO_DB_DRIVER=sqlite
NEO_SQLITE_PATH=neo.db
NEO_MYSQL_HOST=127.0.0.1
NEO_MYSQL_PORT=3306
NEO_MYSQL_USER=root
NEO_MYSQL_PASSWORD=
NEO_MYSQL_DATABASE=neo_harness
NEO_MYSQL_CHARSET=utf8mb4

# Harness behavior
NEO_ENABLE_SHELL=1
NEO_TOOL_TIMEOUT_SECONDS=60
NEO_MAX_AGENT_LOOPS=12
NEO_AUTO_RECOVERY_MAX=2
